# ─── Local Development Environment ──────────────────────────────────────────
#
# Copy this file to .env.local for local development with Docker Compose.
# Generate fresh JWT tokens:  node scripts/gen-dev-jwt.mjs
#
# The tokens below are pre-generated for the default JWT secret.
# They are NOT secret — do not use in production.

# ── Database (Docker) ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres
PGRST_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ── Supabase (local Docker stack on port 8000) ───────────────────────────────
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWxvY2FsIiwiaWF0IjoxNzcyNTYwMDAwLCJleHAiOjIwODg5MjAwMDB9.-shxa18O67aQuL6DxC8tHjLQf-PXP2DvTkkwwRUN7So
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtbG9jYWwiLCJpYXQiOjE3NzI1NjAwMDAsImV4cCI6MjA4ODkyMDAwMH0.TDc2ostLxy1igebnAXdfWjIZORJioPzGOmaSNiZEOJA

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=local-dev-nextauth-secret-change-in-production

# ── Shopify (add your test app credentials) ───────────────────────────────────
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ── AI Platforms ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
PERPLEXITY_SONAR_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
SEMRUSH_API_KEY=

# ── Cron (local testing: use this value in Authorization: Bearer header) ──────
CRON_SECRET=local-cron-secret

# ── Stripe (use test keys) ────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=# Create test prices at dashboard.stripe.com > Products
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
STRIPE_PRICE_ID_ENTERPRISE=
# ── Resend ────────────────────────────────────────────────────────────────────
# RESEND_FROM_EMAIL: use Resend's shared test address until you verify a domain
RESEND_API_KEY=
RESEND_FROM_EMAIL=AgenticRev <onboarding@resend.dev>

# ── Optional AI concierge override ────────────────────────────────────────────
AGENT_MODEL=gpt-5.4-mini
